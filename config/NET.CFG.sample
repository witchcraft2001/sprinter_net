# Sprinter DSS Network Kit configuration template.
# Copy this file to NET.CFG and edit it for your local Wi-Fi network.
# Do not commit a real NET.CFG with private credentials.
#
# Lines starting with # are comments. Unknown keys are ignored.
#
# SSID: Wi-Fi network name.
SSID=
#
# PASS: Wi-Fi password. Leave empty for open networks.
PASS=
#
# DHCP: 1 = use DHCP, 0 = use static IP settings below.
DHCP=1
#
# Static IPv4 settings. Used only when DHCP=0.
IP=
GATEWAY=
NETMASK=
#
# DNS servers. Used when the ESP-AT firmware supports manual DNS setup.
DNS1=1.1.1.1
DNS2=8.8.8.8
#
# TZ: time zone offset from UTC, used by NTP/SNTP tools.
TZ=+6
#
# NTP: default network time server.
NTP=pool.ntp.org
#
# AUTOJOIN: 1 = tools may connect automatically using this config.
AUTOJOIN=1
#
# BAUD: UART speed used after NETUP configures ESP with AT+UART_CUR.
# Supported values: 115200, 57600, 38400, 19200, 9600.
# Use 57600 or 38400 if 115200 loses bytes on your setup.
BAUD=115200
